---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ui/contact-form.tsx";
import linkedinIcon from "../assets/linkedin.svg";
import dribbbleIcon from "../assets/dribbble.svg";
---

<BaseLayout title="Contact — Ivan Annikov">
  <Nav activePage="contact" />
  <main>
    <!-- Hero / header -->
    <section>
      <div class="grid-frame">
        <div class="grid-row no-notches bg-[var(--color-surface)] px-6 pt-10 pb-16 md:px-10 md:pt-16 md:pb-24">
          <h1 class="mb-4 text-4xl font-bold tracking-[-0.03em] text-[var(--color-text)] md:text-6xl">
            Get in Touch
          </h1>
          <p class="max-w-xl text-lg leading-relaxed text-[var(--color-text-muted)]">
            Have a project in mind? I'd love to hear about it. Send me a message and I'll get back to you as soon as possible.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact form + supporting info -->
    <section>
      <div class="grid-frame">
        <div class="grid-row px-6 py-12 md:px-10 md:py-16">
          <div class="flex flex-col gap-12 md:flex-row md:gap-16">

            <!-- Left: contact form -->
            <div class="md:w-2/3">
              <ContactForm client:load />
            </div>

            <!-- Right: supporting info — hidden on mobile -->
            <div class="hidden md:block md:w-1/3 md:border-l md:border-black/[0.18] md:pl-10 lg:pl-14">
              <!-- Location -->
              <div class="mb-8">
                <h3 class="mb-2 text-sm font-medium uppercase tracking-[0.08em] text-[var(--color-text-muted)]">
                  Location
                </h3>
                <p class="flex items-center gap-2 text-base text-[var(--color-text)]">
                  <svg class="h-4 w-4 text-[var(--color-text-muted)]" viewBox="0 0 24 24" fill="currentColor">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" />
                  </svg>
                  Portland, Maine
                </p>
              </div>

              <!-- Resume download -->
              <div class="mb-8">
                <h3 class="mb-2 text-sm font-medium uppercase tracking-[0.08em] text-[var(--color-text-muted)]">
                  Resume
                </h3>
                <a
                  href="/resume.pdf"
                  download
                  class="inline-flex items-center gap-2 text-base font-medium text-[var(--color-text)] transition-colors hover:text-[var(--color-accent)]"
                >
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                  </svg>
                  Download PDF
                </a>
              </div>

              <!-- Social links -->
              <div>
                <h3 class="mb-3 text-sm font-medium uppercase tracking-[0.08em] text-[var(--color-text-muted)]">
                  Social
                </h3>
                <div class="flex items-center gap-4">
                  <a
                    href="https://www.linkedin.com/in/iannikov/"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="LinkedIn"
                    class="flex h-10 w-10 items-center justify-center rounded-full border border-black/[0.18] transition-colors hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/10"
                  >
                    <img src={linkedinIcon.src} alt="" class="h-4 w-4 brightness-0" />
                  </a>
                  <a
                    href="https://dribbble.com/iannikov"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Dribbble"
                    class="flex h-10 w-10 items-center justify-center rounded-full border border-black/[0.18] transition-colors hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/10"
                  >
                    <img src={dribbbleIcon.src} alt="" class="h-4 w-4 brightness-0" />
                  </a>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
