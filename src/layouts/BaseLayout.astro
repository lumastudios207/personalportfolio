---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Ivan Annikov — Fractional Product Designer" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ivan Annikov — Fractional Product Designer specializing in UX/UI for SaaS products." />

    <!-- Google Fonts: IBM Plex Sans 400, 500, 600, 700 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
