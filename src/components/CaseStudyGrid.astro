---
import constructo from "../assets/work/constructo.png";
import selectedProjectsImg from "../assets/selected-projects-img.png";
import corepilot from "../assets/work/corepilot.png";
import screensteps from "../assets/work/screensteps.png";
import secureframe from "../assets/work/secureframe.png";
import splitero from "../assets/work/splitero.png";
import stellar from "../assets/work/stellar.png";
import upwave from "../assets/work/upwave.png";

const projects = [
  {
    company: "CorePilot",
    description: "CorePilot is building a modern ERP that brings real-time intelligence to the aviation parts aftermarket. Designed for brokers, distributors, and MRO teams, it replaces legacy systems with streamlined workflows and AI-powered automations.",
    workTypes: ["Product Design"],
    slug: "corepilot",
    image: corepilot,
  },
  {
    company: "Splitero",
    description: "Splitero is a San Diego-based software company that offers a flexible and less stressful alternative to traditional home equity loans. Homeowners use Splitero to access their equity without income or credit score requirements for eligibility, managing the entire application process through Splitero's web app.",
    workTypes: ["Product Design", "Marketing Design"],
    slug: "splitero",
    image: splitero,
  },
  {
    company: "Secureframe",
    description: "Secureframe is a venture-funded startup based in San Francisco that develops security and compliance software. Hundreds of startups and larger tech companies use Secureframe to automate their SOC 2 and ISO 27001 compliance.",
    workTypes: ["Product Design", "Marketing Design"],
    slug: "secureframe",
    image: secureframe,
  },
  {
    company: "Upwave",
    description: "Upwave is a Bay Area startup that offers tools for brands, agencies, and publishers to optimize advertising strategies across various channels. With real-time data and customizable dashboards, Upwave enables users to make data-driven decisions and enhance brand performance.",
    workTypes: ["Product Design"],
    slug: "upwave",
    image: upwave,
  },
  {
    company: "Constructo",
    description: "Constructo offers a comprehensive solution that simplifies and enhances each stage of residential pre-construction projects. From 3D scans and as-builts to permit-ready plan sets, Constructo integrates advanced technology and user-friendly features to ensure accuracy, efficiency, and collaboration.",
    workTypes: ["Product Design", "Marketing Design"],
    slug: "constructo",
    image: constructo,
  },
  {
    company: "StellarAero",
    description: "Stellar brings together the most advanced technologies and data science to streamline business aviation for both travelers and fleet operators. It offers advanced software solutions that fleet operators use for charter quoting, off-fleet sourcing, and data analysis.",
    workTypes: ["Product Design"],
    slug: "stellar",
    image: stellar,
  },
  {
    company: "ScreenSteps",
    description: "ScreenSteps is building sophisticated knowledge base software which enables large companies such as Dell and Vimeo to easily create internal procedure documentation and operations-based training courses.",
    workTypes: ["Product Design"],
    slug: "screensteps",
    image: screensteps,
  },
];
---

<section class="bg-[var(--color-background)]">
  <div class="grid-frame-dark">
    <!-- Section label row -->
    <div class="grid-row-dark no-notches px-6 py-4 md:px-10">
      <span class="grid-label text-white">Work</span>
    </div>

    <!-- Section header -->
    <div class="grid-row-dark relative flex flex-col gap-5 px-6 py-12 md:h-[280px] md:justify-center md:px-10 md:py-0">
      <div class="hidden md:block absolute inset-y-0 right-0 w-[33.333%] overflow-hidden">
        <img
          src={selectedProjectsImg.src}
          alt="Selected projects illustration"
          class="h-full w-full object-cover"
        />
      </div>
      <div class="md:w-2/3">
        <h2 class="text-3xl font-medium tracking-[-0.03em] text-white md:text-5xl">
          Featured Projects
        </h2>
        <p class="mt-5 max-w-3xl text-base leading-relaxed text-white/70">
          A cross-section of the work I'm most proud of — from complex enterprise platforms to brand-new SaaS tools finding their first users. Each project brought a different challenge — but they all share a focus on thoughtful product thinking while building software that actually ships.
        </p>
      </div>
    </div>

    <!-- Project cards — text left, image right -->
    {projects.map((project) => (
      <div class="grid-row-dark grid grid-cols-1 md:grid-cols-[45%_55%] md:h-[480px]">
        <div class="flex flex-col justify-between gap-6 p-6 md:gap-10 md:p-10 overflow-hidden">
          <div class="flex flex-col gap-4">
            <span class="grid-label text-[var(--color-text-muted)] flex items-center gap-2">
              {project.workTypes.map((type, i) => (
                <>
                  {i > 0 && <span class="inline-block h-1 w-1 rounded-full bg-[var(--color-accent)]"></span>}
                  <span>{type}</span>
                </>
              ))}
            </span>
            <h3 class="text-xl font-medium text-white md:text-3xl">
              {project.company}
            </h3>
            <p class="leading-relaxed text-white/70">
              {project.description}
            </p>
          </div>
          <a
            href={`/work/${project.slug}`}
            class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-accent)] transition-opacity hover:opacity-80 w-fit"
          >
            View Details
            <svg class="h-4 w-4 transition-transform hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
        <div class="grid-divider-dark bg-white/[0.06] p-4 md:p-6 flex">
          <a href={`/work/${project.slug}`} class="group block relative flex-1 min-h-60 overflow-hidden rounded">
            <img
              src={project.image.src}
              alt={`${project.company} project preview`}
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
            />
          </a>
        </div>
      </div>
    ))}
  </div>
</section>
