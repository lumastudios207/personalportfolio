---
import ServicePanels from "./ui/service-panels.tsx";
import sideImage from "../assets/expertise-img.png";
---

<section class="bg-[var(--color-background)]">
  <div class="grid-frame-dark">
    <!-- Section label row -->
    <div class="grid-row-dark no-notches px-6 py-4 md:px-10">
      <span class="grid-label text-white">About Me</span>
    </div>

    <!-- Section header -->
    <div class="grid-row-dark relative flex flex-col gap-5 px-6 py-12 md:h-[280px] md:justify-center md:px-10 md:py-0">
      <div class="hidden md:block absolute inset-y-0 right-0 w-[33.333%] overflow-hidden">
        <img
          src={sideImage.src}
          alt="Design illustration"
          class="h-full w-full object-cover"
        />
      </div>
      <div class="md:w-2/3">
        <h2 class="text-3xl font-medium tracking-[-0.03em] text-white md:text-5xl">
          15+ Years of Product Design
        </h2>
        <p class="mt-5 max-w-3xl text-base leading-relaxed text-white/70">
          After spending a good portion of my career in senior UX/UI design roles at a number of Silicon Valley tech companies, I currently work as an independent product designer, focusing on enterprise-grade software and SaaS platforms. I use Figma, Storybook, and various AI tools to accelerate build cycles for interactive prototypes and delivery of production-ready components for engineering teams. Tighter loop, faster iteration, less lost in translation.
        </p>
      </div>
    </div>

    <!-- Panels with corners card variant -->
    <div class="grid-row-dark">
      <ServicePanels client:visible />
    </div>
  </div>
</section>
