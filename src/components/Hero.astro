---
import heroBg from "../assets/hero-background.png";
import myPicture from "../assets/mypicture.png";
---

<section>
  <div class="grid-frame grid-row no-notches relative flex flex-col justify-center overflow-hidden bg-[var(--color-surface)] px-6 py-16 md:py-24">

    <!-- Background image (removed) -->

    <!-- Two-column layout: image area left, copy right -->
    <div class="relative z-10 flex flex-col md:flex-row md:items-start md:gap-10">

      <!-- Left: image — hidden on mobile, shown on desktop -->
      <div class="hidden md:block md:w-1/3 md:pt-1">
        <div class="ml-16">
          <img src={myPicture.src} alt="Ivan Annikov" class="w-full max-w-[280px] object-contain" />
        </div>
      </div>

      <!-- Right: all copy -->
      <div class="md:w-2/3">
        <!-- Name + mobile portrait inline -->
        <div class="mb-6 flex items-center gap-4">
          <img src={myPicture.src} alt="Ivan Annikov" class="h-20 w-auto shrink-0 object-contain md:hidden" />
          <div class="flex flex-col justify-center">
            <h1 class="text-3xl font-bold leading-none tracking-[-0.03em] text-[var(--color-text)] md:text-5xl">
              Hi, I'm Ivan.
            </h1>
            <!-- Location — mobile -->
            <p class="mt-2 flex items-center gap-1.5 text-[17px] font-semibold text-[var(--color-text-muted)] md:hidden">
              <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" />
              </svg>
              Portland, Maine
            </p>
          </div>
        </div>
        <!-- Location — desktop -->
        <p class="mb-5 hidden items-center gap-1.5 text-base text-[rgb(22,23,27)] md:flex">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" />
          </svg>
          Working remotely from <span class="font-semibold text-[rgb(22,23,27)]">Portland, Maine</span>
        </p>

        <!-- Subtitle -->
        <p class="mb-8 max-w-2xl text-2xl font-normal leading-snug text-[var(--color-text)] md:text-3xl">
          I design software products and build systems that close the gap between design and engineering.
        </p>

        <!-- Credential callouts — stacked vertical list with accent markers -->
        <div>
          <ul class="flex flex-col gap-4">
            <li class="flex items-center gap-3">
              <span class="h-2 w-2 shrink-0 rounded-full bg-[var(--color-accent)]"></span>
              <span class="text-sm font-medium uppercase tracking-[0.08em] text-[var(--color-text)]">15+ Years of Design Experience</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="h-2 w-2 shrink-0 rounded-full bg-[var(--color-accent)]"></span>
              <span class="text-sm font-medium uppercase tracking-[0.08em] text-[var(--color-text)]">AI-Augmented Workflows</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="h-2 w-2 shrink-0 rounded-full bg-[var(--color-accent)]"></span>
              <span class="text-sm font-medium uppercase tracking-[0.08em] text-[var(--color-text)]">Code-Based Deliverables</span>
            </li>
          </ul>
        </div>
      </div>

    </div>

  </div>
</section>
