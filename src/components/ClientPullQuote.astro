---
interface Props {
  quote: string;
  clientLogo: string;
  company: string;
  authorName?: string;
  authorRole?: string;
  quotePanelImage?: string;
  quoteLogoWhite?: string;
  quoteLogoSize?: string;
}

const { quote, clientLogo, company, authorName, authorRole, quotePanelImage, quoteLogoWhite, quoteLogoSize = "h-16 max-w-[200px]" } = Astro.props;
---

<section>
  <div class="grid-frame">
    <div class="grid-row no-left-notch relative px-6 py-10 md:px-10 md:py-16">

      <!-- Left image panel with centered white logo -->
      {quotePanelImage && (
        <div class="hidden md:flex absolute inset-y-0 left-0 w-[33.333%] overflow-hidden items-center justify-center">
          <img
            src={quotePanelImage}
            alt=""
            class="absolute inset-0 h-full w-full object-cover"
          />
          {quoteLogoWhite && (
            <img
              src={quoteLogoWhite}
              alt={`${company} logo`}
              class={`relative z-10 w-auto object-contain ${quoteLogoSize}`}
            />
          )}
        </div>
      )}

      <!-- Full-height vertical divider line -->
      {quotePanelImage && (
        <div class="hidden md:block absolute inset-y-0 left-[33.333%] w-px bg-black/[0.18] z-[1]"></div>
      )}

      <!-- Quote content — right side -->
      <div class:list={["relative z-[2]", quotePanelImage && "md:ml-[33.333%] md:pl-10 lg:pl-14"]}>
        <div class="flex max-w-2xl flex-col">

          <!-- Quote marks -->
          <div class="relative mb-6">
            <svg class="absolute -right-[65px] -top-4 h-16 w-auto md:-top-6 md:h-24" viewBox="0 0 200 128" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M86,0L86,85.3L43,85.3L43,128C19.3,128,0,108.9,0,85.3L0,0L86,0z M200,0L200,85.3L157,85.3L157,128C133.3,128,114,108.9,114,85.3L114,0L200,0z" fill="#F7F7F7" />
            </svg>
          </div>

          <!-- Quote -->
          <div class="relative mb-6">
            <blockquote class="pl-4 text-lg italic font-light leading-relaxed tracking-tight text-[var(--color-text)] md:pl-6 md:text-xl">
              {quote}
            </blockquote>
          </div>

          <!-- Attribution with accent line -->
          {authorName && (
            <div class="relative pl-5 py-1">
              <div class="absolute bottom-0 left-0 top-0 w-px bg-[var(--color-accent)]"></div>
              <span class="block text-base font-medium tracking-wide text-[var(--color-text)] md:text-lg">
                {authorName}
              </span>
              {authorRole && (
                <span class="mt-1 block text-sm uppercase tracking-widest text-[var(--color-text-muted)]">
                  {authorRole} — {company}
                </span>
              )}
            </div>
          )}

        </div>
      </div>
    </div>
  </div>
</section>
