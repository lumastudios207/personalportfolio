---
import linkedinIcon from "../assets/linkedin.svg";
import dribbbleIcon from "../assets/dribbble.svg";

const currentYear = new Date().getFullYear();
---

<footer>
  <div class="grid-frame">
    <div class="grid-row no-notches flex flex-col items-center gap-6 px-6 py-12 md:flex-row md:justify-between">
      <!-- Left: copyright + location -->
      <div class="flex flex-col items-center gap-1 text-center md:items-start md:text-left">
        <p class="text-sm text-[var(--color-text-muted)]">
          &copy; {currentYear} Ivan Annikov. All rights reserved.
        </p>
      </div>

      <!-- Right: social icons -->
      <div class="flex items-center gap-4">
        <a
          href="https://www.linkedin.com/in/iannikov/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="flex h-10 w-10 items-center justify-center rounded-full transition-opacity hover:opacity-70"
        >
          <img src={linkedinIcon.src} alt="" class="h-5 w-5 brightness-0" />
        </a>
        <a
          href="https://dribbble.com/iannikov"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Dribbble"
          class="flex h-10 w-10 items-center justify-center rounded-full transition-opacity hover:opacity-70"
        >
          <img src={dribbbleIcon.src} alt="" class="h-5 w-5 brightness-0" />
        </a>
      </div>
    </div>
  </div>
</footer>
